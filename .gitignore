# Local overrides (not tracked)
system/.alias.custom
system/.deepjudge
packages/git/.gitconfig.local
packages/ssh/.ssh/config.local

# Karabiner automatic backups
packages/karabiner/.config/karabiner/automatic_backups/

# Herdr runtime state
.config/herdr/*.log
.config/herdr/*.sock
.config/herdr/session.json
.config/herdr/session-history.json
.config/herdr/scripts/__pycache__/

# OS files
.DS_Store
