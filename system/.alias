# Npm aliases
alias ni='npm install'
alias nis='npm install --save --save-exact'
alias nid='npm install --save-dev --save-exact'
alias nig='npm install --global --save-exact'
alias nui='npm uninstall'
alias nuis='npm uninstall --save'
alias nuid='npm uninstall --save-dev'
alias nuig='npm uninstall --global'
alias ns='npm start'
alias nt='npm test'
alias nit='npm install && npm test'
alias nk='npm link'
alias nr='npm run'
alias nf='npm cache clean && rm -rf node_modules && npm install'

# System aliases
alias ls="eza"
alias las="eza -al"
# alias ls='nnn -de'
# alias lf='lfcd'

# Random cmdline apps
alias e='nvim'
# alias e='$EDITOR'
alias x='exit'
alias k='clear'
alias r='renamer'
alias icat="kitty +kitten icat"
alias mdn="glow --style ~/.dotfiles/.config/glow/glow.styles.json"
alias json="fx"
alias lg='lazygit'

# Dotfiles aliases
alias dota='e ~/.dotfiles/system/.alias'
alias dotf='e ~/.dotfiles/system/.function'
alias dots='e ~/.dotfiles/.config/sesh/sesh.toml'

# Cat replacement with colors
alias cat='bat --style="grid"'

# CD paths
alias cd="z" # Remap cd to use the z command from zoxide, a better cd command
alias r="cd ~/repos"

# Apps
alias c="code -n ." # Visual studio code
# alias vim='nvim -u $MYVIMRC'
alias sourcetree='open -a SourceTree'
alias chrome='/Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --kiosk'

# Open dotfiles in vim
alias dot="e ~/.dotfiles"

# ProtonVPN
alias pt="protonvpn-cli"
alias ptc="protonvpn-cli c --fastest"
alias ptd="protonvpn-cli d"
alias pts="protonvpn-cli status"

# list processes running on specific port (takes port as additional arg)
# eg. pp 3000
alias pp="lsof -nP -iTCP -sTCP:LISTEN | grep "

# Source the zsh config
alias so='source ~/.zshrc && clear'

# Git overrides
alias glsr='serie -p kitty'
alias glb="git for-each-ref --sort=-committerdate refs/heads/ --format='%(color:yellow)%(refname:short)%(color:reset)'"
alias gbcp="git rev-parse --abbrev-ref HEAD | h"

# Workmux
alias wma="workmux add"
alias wmr="workmux remove"
alias wmm="workmux merge"
alias wml="workmux list"

# GitHub Stack CLI
alias gs="gh stack"
alias gsvi="gh stack view"
alias gsad="gh stack add"
alias gsup="gh stack up"
alias gsdn="gh stack down"
alias gsto="gh stack top"
alias gsbt="gh stack bottom"
alias gsit="gh stack init"
alias gsph="gh stack push"
alias gsrb="gh stack rebase"
alias gssc="gh stack sync"
alias gswt="gh stack switch"
alias gsco="gh stack checkout"
alias gsmg="gh stack merge"

# DeepJudge Specific
alias djl="pnpm exec eslint components pages features lib state scripts --ext .js,.jsx,.ts,.tsx,.mjs --cache --cache-location .next/cache/eslint/ --quiet --rule 'import/namespace: off' --rule 'import/default: off' --rule 'import/no-named-as-default: off' --rule 'import/no-named-as-default-member: off'"

